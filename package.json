{
  "name": "moneymoney",
  "version": "1.3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node --max-old-space-size=8192 node_modules/.bin/vite build",
    "eslint": "eslint .",
    "preview": "vite preview",
    "release": "node src/scripts/release.js",
    "translate": "vue-i18n-extract --vueFiles './src/**/*.?(js|vue)' --languageFiles './src/locales/**/*.?(json|yaml|yml|js)' --add true --remove true --separator '###'  --missingTranslationString 'MISSING'",
    "vitest": "vitest --passWithNoTests",
    "playwright": "playwright test --ui --output output/playwright",
    "playwright_console": "playwright test --output output/playwright",
    "playwright_coverage": "nyc --reporter=lcov --report-dir  output/coverage  playwright test"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "axios": "^1.13.6",
    "currency-list": "^1.0.8",
    "echarts": "^6.0.0",
    "echarts-stat": "^1.2.0",
    "flag-icons": "^7.5.0",
    "lodash-es": "^4.17.23",
    "moment-timezone": "^0.6.1",
    "pdfmake": "^0.3.7",
    "pinia": "^3.0.4",
    "roboto-fontface": "*",
    "vitest": "^4.1.0",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.3",
    "vuetify_rules": "^0.7.0",
    "webfontloader": "^1.6.28"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "eslint": "^10.1.0",
    "eslint-plugin-playwright": "^2.10.1",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "npm-check-updates": "^19.6.5",
    "nyc": "^18.0.0",
    "playwright": "^1.58.2",
    "vite": "^8.0.1",
    "vite-plugin-eslint": "^1.8.1",
    "vite-plugin-istanbul": "^8.0.0",
    "vite-plugin-vue-devtools": "^8.1.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-i18n-extract": "github:Spittal/vue-i18n-extract"
  },
  "nyc": {
    "extension": [
      ".js",
      ".vue"
    ]
  }
}
